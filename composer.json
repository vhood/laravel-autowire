{
  "name": "vhood/laravel-autowire",
  "description": "Clean and production-ready DI autowiring via PHP 8 attributes for Laravel.",
  "keywords": [
    "laravel",
    "ddd",
    "autowire",
    "di",
    "dependency-injection",
    "attributes"
  ],
  "license": "MIT",
  "authors": [
    {
      "name": "Viktor Khramov",
      "email": "dev.999.victor@gmail.com"
    }
  ],
  "require": {
    "php": "^8.1",
    "illuminate/support": "^10.0|^11.0|^12.0",
    "illuminate/console": "^10.0|^11.0|^12.0",
    "symfony/finder": "^6.0|^7.0",
    "composer/class-map-generator": "^1.7"
  },
  "require-dev": {
    "orchestra/testbench": "^8.0|^9.0|^10.0",
    "pestphp/pest": "^2.0|^3.0",
    "laravel/pint": "^1.29",
    "phpstan/phpstan": "^2.2"
  },
  "autoload": {
    "psr-4": {
      "Vhood\\Laravel\\Autowire\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Vhood\\Laravel\\AutowireTests\\": "tests/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "Vhood\\Laravel\\Autowire\\AutowireServiceProvider"
      ]
    }
  },
  "config": {
    "allow-plugins": {
      "pestphp/pest-plugin": true
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
